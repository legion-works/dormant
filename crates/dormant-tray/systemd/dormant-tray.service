[Unit]
Description=dormant tray — StatusNotifierItem indicator for dormantd
Documentation=https://github.com/iceteaSA/dormant
After=graphical-session.target dormant.service
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/.local/bin/dormant-tray
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
